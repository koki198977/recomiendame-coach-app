{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "distribution": "internal"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "tu-email@ejemplo.com",
        "ascAppId": "TU_APP_STORE_CONNECT_ID",
        "appleTeamId": "TU_TEAM_ID"
      }
    },
    "alpha": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "alpha"
      }
    },
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      },
      "ios": {
        "appleId": "tu-email@ejemplo.com",
        "ascAppId": "TU_APP_STORE_CONNECT_ID",
        "appleTeamId": "TU_TEAM_ID"
      }
    }
  }
}
